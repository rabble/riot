<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Mirrors the proven divine-mobile export config (same Apple team). Pairs
	     with scripts/testflight-release.sh. Produces a signed .ipa to export;
	     the upload step is a separate authenticated command in the script. -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>teamID</key>
	<string>GZCZBKH7MY</string>
	<!-- Automatic signing matches the project (CODE_SIGN_STYLE = Automatic).
	     Requires an Xcode account authorized on team GZCZBKH7MY, or the archive/
	     export must run with -allowProvisioningUpdates and an ASC API key. -->
	<key>signingStyle</key>
	<string>automatic</string>
	<key>uploadSymbols</key>
	<true/>
	<key>uploadBitcode</key>
	<false/>
	<key>compileBitcode</key>
	<false/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>

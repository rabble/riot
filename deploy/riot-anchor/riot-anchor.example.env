# deploy/riot-anchor/riot-anchor.example.env
#
# Copy to riot-anchor.env (next to compose.yaml), fill in the secrets, and
# NEVER commit riot-anchor.env. Exact variable names come from
# crates/riot-anchor/src/config.rs — the configuration authority.
#
# NOTE: the database path is NOT configured here. It is the --db CLI flag
# (compose.yaml passes --db /var/lib/riot-anchor/anchor.sqlite3).

# REQUIRED — the 32-byte Ed25519 operator SECRET seed, as 64 hex chars.
# Generate:  openssl rand -hex 32
# Signs the anchor descriptor and every control-plane receipt. On FIRST boot it
# also derives the proposals for the database-durable secrets (genesis random,
# namespace-token secret) and the deployment token binding this database to
# this deployment. Keep it secret; keep it backed up.
RIOT_ANCHOR_OPERATOR_KEY_HEX=

# RECOMMENDED — the 32-byte Ed25519 secret giving the public endpoint its
# STABLE iroh NodeId (what clients dial / discover). Generate the same way:
#   openssl rand -hex 32
# If unset the daemon warns and mints an EPHEMERAL identity: the NodeId then
# changes on every restart and clients lose the address.
RIOT_ANCHOR_ENDPOINT_KEY_HEX=

# Optional descriptor metadata (defaults in parentheses).
RIOT_ANCHOR_DISPLAY_LABEL=my-anchor
#RIOT_ANCHOR_HTTPS_ORIGIN=https://anchor.example.org     # (https://localhost)
#RIOT_ANCHOR_FAILURE_DOMAIN=my-basement                  # (unknown)

# Optional concurrency ceiling — control and sync sessions share it.
#RIOT_ANCHOR_MAX_CONTROL_SESSIONS=64

# File-based secret variants (for docker/compose secrets mounts). If both are
# set for a key, the _HEX form wins.
#RIOT_ANCHOR_OPERATOR_KEY_FILE=/run/secrets/riot-anchor-operator.hex
#RIOT_ANCHOR_ENDPOINT_KEY_FILE=/run/secrets/riot-anchor-endpoint.hex

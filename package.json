{
  "name": "riot-web-tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": "26.4.0",
    "npm": "11.17.0"
  },
  "scripts": {
    "test:web:unit": "node --test scripts/web/test/*.test.mjs",
    "test:web:coverage": "c8 --100 --all --include='scripts/web/**/*.mjs' node --test scripts/web/test/*.test.mjs",
    "test:apps:unit": "node --test scripts/apps/test/*.test.mjs",
    "test:marketing": "node --test scripts/marketing/test/*.test.mjs && node scripts/marketing/protocol-page-contracts.mjs",
    "verify:marketing:live": "node scripts/marketing/verify-live.mjs",
    "test:release:unit": "node --test scripts/release/test/*.test.mjs",
    "test:release:coverage": "c8 --100 --all --include=scripts/release/**/*.mjs --exclude=scripts/release/test/** node --test scripts/release/test/*.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "ajv": "8.20.0",
    "c8": "11.0.0",
    "selenium-webdriver": "4.46.0"
  }
}
